---
// Props: headline, image, imageAlt
import { Image } from "astro:assets";
const { headline, image, imageAlt } = Astro.props;
---

<div class="hero-section">
  <h1 class="hero-headline">{headline}</h1>
  <Image src={image} alt={imageAlt} class="hero-image" />
</div>

<style>
  .hero-section {
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 10px;
  }

  .hero-headline {
    font-size: 40px;
    color: var(--color-ink);
    font-weight: 600;
    margin: 0;
    margin-bottom: 1rem;
    letter-spacing: -1.6px;
  }

  .hero-image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-image);
    min-height: 200px;
  }

  @media (max-width: 960px) {
    .hero-headline {
      font-size: 32px;
    }
  }
</style>
