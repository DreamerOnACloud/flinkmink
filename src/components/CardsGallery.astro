---
// Props: posts (pre-sorted array of collection entries)
import Card from "./Card.astro";
const { posts } = Astro.props;
---

<section class="cards-gallery">
  <h1 class="gallery-headline">Latest blog posts</h1>
  <div class="card-grid">
    {posts.map((post) => (
      <Card
        title={post.data.title}
        date={post.data.date}
        description={post.data.description}
        image={post.data.image}
        imageAlt={post.data.title}
        href={`/blog/${post.slug}`}
      />
    ))}
  </div>
</section>

<style>
  .cards-gallery {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .gallery-headline {
    font-size: 40px;
    color: var(--color-ink);
    font-weight: 600;
    margin: 0;
    margin-bottom: 1rem;
    letter-spacing: -1.6px;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    padding-bottom: 40px;
  }

  @media (max-width: 960px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .gallery-headline {
      font-size: 32px;
    }
  }

  @media (max-width: 640px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
