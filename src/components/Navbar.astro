---
import { Image } from "astro:assets";
import LogoImg from "../images/flinkmink-logo.png";
import MenuImg from "../images/feather--menu.svg";
import { NAV_LINKS, BRAND } from "../config/site.js";

const pathname = Astro.url.pathname;
const isActive = (href) => href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<nav class="navbar">
  <a href="/">
    <div class="logo-container">
      <div class="logo-img">
        <Image src={LogoImg} alt="logo" width={32} />
      </div>
      <div class="logo-text">{BRAND}</div>
    </div>
  </a>

  <button class="menu-btn" aria-label="Toggle navigation">
    <Image src={MenuImg} alt="" width={40} />
  </button>

  <ul class="nav-links">
    {NAV_LINKS.map(({ href, label }) => (
      <li>
        <a href={href} class={isActive(href) ? 'active' : ''}>{label}</a>
      </li>
    ))}
  </ul>
</nav>

<script>
  const btn = document.querySelector('.menu-btn');
  const links = document.querySelector('.nav-links');
  btn?.addEventListener('click', () => {
    const open = links?.getAttribute('data-open') === 'true';
    links?.setAttribute('data-open', String(!open));
  });
</script>

<style>
  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    position: sticky;
    top: 0;
    z-index: 10;
    box-shadow: var(--shadow-nav);
    background-color: var(--color-panel);
  }

  .logo-container {
    display: flex;
    align-items: center;
    padding: 0.2rem 0.5rem;
    color: var(--color-navy);
    font-weight: bold;
    font-size: 1.2rem;
  }

  .logo-img {
    height: 30px;
    margin-right: 0.5rem;
  }

  .menu-btn {
    display: none;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 1rem;
    margin: 0;
    padding: 0;
  }

  .navbar a {
    text-decoration: none;
    font-weight: bold;
    color: black;
  }

  .navbar a.active {
    color: var(--color-primary);
  }

  @media (max-width: 800px) {
    .menu-btn {
      display: block;
    }

    .nav-links {
      display: none;
      flex-direction: column;
      position: absolute;
      top: 103%;
      left: 0;
      background: var(--color-surface);
      width: 100%;
      height: calc(100vh - 80px);
      box-sizing: border-box;
      padding: 8px;
    }

    .nav-links[data-open="true"] {
      display: flex;
    }

    .nav-links li a {
      display: flex;
      height: fit-content;
      font-size: 24px;
      margin: 4px 0;
    }

    .nav-links li:hover {
      background-color: var(--color-hover-bg);
    }
  }

  @media (max-width: 640px) {
    .navbar {
      padding: 0.6rem;
    }
  }
</style>
