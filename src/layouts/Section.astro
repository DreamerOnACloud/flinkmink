---
const { variation = "light" } = Astro.props;
---
<div class={`section-bg ${variation}`}>
  <div class="section-content">
    <slot />
  </div>
</div>

<style>
  .section-bg {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: center;
  }

  .section-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    overflow: hidden;
    width: 100%;
    max-width: 1280px;
    padding: var(--space-section);
  }

  .light {
    background-color: var(--color-bg);
  }

  .dark {
    background-color: var(--color-panel);
  }

  @media (max-width: 640px) {
    .section-content {
      padding: var(--space-section-sm);
    }
  }
</style>
