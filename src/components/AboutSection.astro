---
// Props: headline, body, image, imageAlt
import { Image } from "astro:assets";
const { headline, body, image, imageAlt } = Astro.props;
---

<section class="about-section">
  <div class="about-text">
    <h1 class="about-headline">{headline}</h1>
    <p>{body}</p>
  </div>
  <div class="about-image">
    <Image src={image} alt={imageAlt} />
  </div>
</section>

<style>
  .about-section {
    display: flex;
    flex-direction: row;
    gap: 40px;
  }

  .about-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .about-headline {
    font-size: 40px;
    color: var(--color-ink);
    font-weight: 600;
    margin: 0;
    margin-bottom: 1rem;
    letter-spacing: -1.6px;
  }

  .about-text p {
    font-size: 20px;
    line-height: 1.5;
    margin: 0;
  }

  .about-image {
    flex: 1;
  }

  .about-image img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 20px;
  }

  @media (max-width: 768px) {
    .about-section {
      flex-direction: column;
    }

    .about-image,
    .about-text {
      width: 100%;
    }
  }

  @media (max-width: 960px) {
    .about-headline {
      font-size: 32px;
    }
  }
</style>
