---
// Props: title, date, description, image, imageAlt, href
import { Image } from "astro:assets";
import { parsePostDate } from '../utils/posts.js';
const { title, date, description, image, imageAlt, href } = Astro.props;
const formattedDate = parsePostDate(date);
---

<a href={href}>
  <div class="card">
    <div class="image-container">
      <Image src={image} alt={imageAlt} class="post-image" />
    </div>
    <div class="card-content">
      <h2 class="post-title">{title}</h2>
      <p class="date">{formattedDate}</p>
      <p class="description">{description}</p>
    </div>
  </div>
</a>

<style>
  * {
    box-sizing: border-box;
  }

  .card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    height: auto;
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: transform 0.3s ease;
    border-radius: var(--radius-card-lg);
  }

  .card:hover {
    background-color: var(--color-panel);
  }

  .image-container {
    aspect-ratio: 4 / 3;
    flex: 1;
    border-radius: var(--radius-card-lg);
    overflow: hidden;
    background-color: grey;
    max-height: 320px;
  }

  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    flex: 2;
    padding: 1rem;
    gap: 8px;
  }

  .post-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: bold;
  }

  .card-content .date {
    margin: 0.25rem 0;
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .card-content .description {
    margin: 0;
    font-size: 0.95rem;
    max-width: 800px;
    line-height: 120%;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 640px) {
    .card {
      flex-direction: column;
      max-height: 600px;
    }

    .image-container {
      width: 100%;
      height: 60%;
    }
  }
</style>
