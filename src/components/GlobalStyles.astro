---
import '@fontsource-variable/inter';
import '../styles/tokens.css';
---

<style is:global>

html, body {
  min-width: 320px;
}

body {
  margin: 0;
  width: 100%;
  background-color: var(--color-bg);
  color: var(--color-ink);
  font-family: 'Inter Variable', sans-serif;
  font-weight: 400;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

a {
  all: unset;
  cursor: pointer;
}
</style>
