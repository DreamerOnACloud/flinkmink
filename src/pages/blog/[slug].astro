---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import GlobalLayout from "../../layouts/GlobalLayout.astro";
import Section from "../../layouts/Section.astro";
import { sortPosts, parsePostDate } from "../../utils/posts.js";

export const getStaticPaths = async () => {
  const posts = await getCollection("posts");
  const sorted = sortPosts(posts);
  return sorted.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      nextPost: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
};

const { post, nextPost } = Astro.props;
const { Content } = await post.render();
---

<GlobalLayout title={post.data.title}>
  <Section>
    <div class="blog-post-container">
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-date">{parsePostDate(post.data.date)}</div>
      <Image
        src={post.data.image}
        alt={post.data.title}
        class="blog-post-image"
      />
      <Content />
      <div class="next-post-link">
        {nextPost ? (
          <a href={`/blog/${nextPost.slug}`} class="next-post-btn">
            Next post →
          </a>
        ) : (
          <a href="/blog" class="next-post-btn">
            ← Back to Blog posts
          </a>
        )}
      </div>
    </div>
  </Section>
</GlobalLayout>

<style>
  .blog-post-container {
    display: flex;
    flex-direction: column;
    width: 80%;
    padding: 1rem;
    box-sizing: border-box;
    font-size: 20px;
    margin: 4rem 0;
    line-height: 1.6;
  }

  .post-title {
    font-size: 40px;
    color: var(--color-ink);
    font-weight: 600;
    margin: 0;
    margin-bottom: 1rem;
    letter-spacing: -1.6px;
  }

  .post-date {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .blog-post-image {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 2;
    object-fit: cover;
    margin: 1rem 0;
    border-radius: var(--radius-image);
  }

  .next-post-link {
    margin-top: 3rem;
    text-align: right;
  }

  .next-post-btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    background-color: var(--color-btn-bg);
    color: var(--color-surface);
    text-decoration: none;
    border-radius: 4px;
    font-size: 1rem;
  }

  .next-post-btn:hover {
    background-color: var(--color-btn-hover);
  }

  @media (max-width: 1024px) {
    .blog-post-container {
      width: 100%;
      font-size: 16px;
      margin: 2rem 0;
    }
  }

  @media (max-width: 600px) {
    .blog-post-container {
      font-size: 14px;
    }

    .post-title {
      font-size: 32px;
    }
  }
</style>
